{
  "name": "angularpad",
  "publisher": "GrischaTDev",
  "displayName": "AngularPad",
  "icon": "resources/logo.png",
  "description": "Angular command launchpad for VS Code - run Angular, Nx & custom commands, scan workspace scripts, and sync package.json versions across your monorepo with a diff preview.",
  "version": "0.4.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/GrischaTDev/angularpad"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "angular",
    "nx",
    "monorepo",
    "package.json",
    "dependencies",
    "npm",
    "yarn",
    "pnpm",
    "launchpad"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "angularpad.openPanel",
        "title": "AngularPad: Open Panel",
        "icon": "$(zap)"
      },
      {
        "command": "angularpad.runCommand",
        "title": "AngularPad: Run Command"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "angularpad",
          "title": "AngularPad",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "angularpad": [
        {
          "type": "webview",
          "id": "angularpad.panel",
          "name": "Commands",
          "icon": "resources/icon.svg"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
